{
  "appId": "com.aigeniusinstitute.deepthink",
  "productName": "DeepThink",
  "directories": { "output": "release", "buildResources": "resources" },
  "files": [
    "dist/**/*",
    "package.json",
    "resources/**/*"
  ],
  "extraResources": [
    { "from": "../dev-resources/node", "to": "node" },
    { "from": "../dist", "to": "backend", "filter": ["**/*"] },
    { "from": "../web/dist", "to": "web-dist", "filter": ["**/*"] },
    { "from": "../container/agent-runner/dist", "to": "agent-runner/dist", "filter": ["**/*"] },
    { "from": "../container/agent-runner/prompts", "to": "agent-runner/prompts", "filter": ["**/*"] },
    { "from": "../container/agent-runner/package.json", "to": "agent-runner/package.json" },
    { "from": "../container/agent-runner/node_modules", "to": "agent-runner/node_modules", "filter": ["**/*", "!**/*.md", "!**/test/**", "!**/tests/**"] },
    { "from": "../node_modules", "to": "node_modules", "filter": ["**/*", "!**/*.md", "!**/.bin/**", "!**/test/**", "!**/tests/**", "!**/.github/**"] }
  ],
  "linux": {
    "target": [
      { "target": "AppImage", "arch": ["x64"] },
      { "target": "deb", "arch": ["x64"] }
    ],
    "category": "Development",
    "icon": "resources/icon.png",
    "maintainer": "DeepThink"
  }
}
